  "components": {
    "schemas": {
      "AuthResponseDto": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "description": "JWT Access Token",
            "nullable": true
          },
          "accessTokenExpiresAt": {
            "type": "string",
            "description": "Время истечения Access Token",
            "format": "date-time"
          },
          "userId": {
            "type": "integer",
            "description": "ID пользователя",
            "format": "int32"
          },
          "email": {
            "type": "string",
            "description": "Email пользователя",
            "nullable": true
          },
          "name": {
            "type": "string",
            "description": "Имя пользователя",
            "nullable": true
          },
          "refreshToken": {
            "type": "string",
            "description": "Refresh Token (также записывается в cookie)",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ChangePasswordDto": {
        "type": "object",
        "properties": {
          "currentPassword": {
            "type": "string",
            "description": "Текущий пароль",
            "nullable": true
          },
          "newPassword": {
            "type": "string",
            "description": "Новый пароль",
            "nullable": true
          },
          "confirmNewPassword": {
            "type": "string",
            "description": "Подтверждение нового пароля",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateCustomerDto": {
        "required": [
          "email",
          "name"
        ],
        "type": "object",
        "properties": {
          "name": {
            "minLength": 1,
            "type": "string"
          },
          "address": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "phoneNumber": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateInvoiceDto": {
        "required": [
          "customerId",
          "endDate",
          "rows",
          "startDate"
        ],
        "type": "object",
        "properties": {
          "customerId": {
            "type": "integer",
            "description": "ID клиента",
            "format": "int32"
          },
          "startDate": {
            "type": "string",
            "description": "Начало периода работ",
            "format": "date-time"
          },
          "endDate": {
            "type": "string",
            "description": "Конец периода работ",
            "format": "date-time"
          },
          "rows": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CreateInvoiceRowDto"
            },
            "description": "Строки инвойса"
          },
          "comment": {
            "type": "string",
            "description": "Комментарий",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "CreateInvoiceRowDto": {
        "required": [
          "service"
