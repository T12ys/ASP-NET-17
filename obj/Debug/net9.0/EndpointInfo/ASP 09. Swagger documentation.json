          {
            "name": "SortBy",
            "in": "query",
            "description": "Поле сортировки: createdAt, updatedAt, startDate, endDate, totalSum, status",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "SortDirection",
            "in": "query",
            "description": "Направление сортировки: asc, desc",
            "schema": {
              "type": "string"
